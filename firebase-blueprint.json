{
  "entities": {
    "Repair": {
      "title": "Repair",
      "description": "Shoe repair request ticket details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "email": { "type": "string" },
        "shoeModel": { "type": "string" },
        "repairType": { "type": "array" },
        "description": { "type": "string" },
        "photoUrl": { "type": "string" },
        "status": { "type": "string" },
        "price": { "type": "number" },
        "dueDate": { "type": "string" },
        "isSynced": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "receivedBy": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "addonType": { "type": "string" },
        "addonPrice": { "type": "number" },
        "hasInsurance": { "type": "boolean" },
        "insuranceType": { "type": "string" }
      }
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer contact and order count details",
      "type": "object",
      "properties": {
        "phoneNumber": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "totalOrders": { "type": "number" },
        "lastVisit": { "type": "string" }
      }
    },
    "InventoryItem": {
      "title": "InventoryItem",
      "description": "Store inventory stock level metrics",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "minThreshold": { "type": "number" }
      }
    },
    "Insurance": {
      "title": "Insurance",
      "description": "Shoe repair insurance policy coverage documentation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerPhone": { "type": "string" },
        "shoeId": { "type": "string" },
        "planName": { "type": "string" },
        "usageCount": { "type": "number" },
        "maxUsage": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "System and user-specific notifications",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled shoe drop-off or consultation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "serviceType": { "type": "string", "enum": ["Drop-off", "Consultation", "Home Pickup"] },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Cancelled", "Completed"] },
        "createdAt": { "type": "string" }
      },
      "required": ["customerName", "email", "date", "time", "serviceType"]
    },
    "PushSubscription": {
      "title": "PushSubscription",
      "description": "Web push notification subscription details",
      "type": "object",
      "properties": {
        "endpoint": { "type": "string" },
        "expirationTime": { "type": "string", "format": "date-time" },
        "keys": {
          "type": "object",
          "properties": {
            "p256dh": { "type": "string" },
            "auth": { "type": "string" }
          }
        },
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "repairs": {
      "schema": "Repair",
      "description": "Collection of shoe repair requests"
    },
    "customers": {
      "schema": "Customer",
      "description": "Collection of customer contact info and history"
    },
    "inventory": {
      "schema": "InventoryItem",
      "description": "Collection of material inventory"
    },
    "insurance": {
      "schema": "Insurance",
      "description": "Collection of active insurance policies"
    },
    "notifications": {
      "schema": "Notification",
      "description": "Collection of user notifications"
    },
    "profiles": {
      "schema": "UserProfile",
      "description": "Collection of user profiles"
    },
    "appointments": {
      "schema": "Appointment",
      "description": "Collection of scheduled appointments"
    },
    "push_subscriptions": {
      "schema": "PushSubscription",
      "description": "Collection of web push subscriptions"
    }
  }
}
