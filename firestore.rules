rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /repairs/{id} {
      allow read, write: if request.auth != null;
    }
    match /customers/{id} {
      allow read, write: if request.auth != null;
    }
    match /inventory/{id} {
      allow read, write: if request.auth != null;
    }
    match /insurance/{id} {
      allow read, write: if request.auth != null;
    }
    match /notifications/{id} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
    }
    match /profiles/{uid} {
      allow read, write: if request.auth != null;
    }
    match /messages/{id} {
      allow read, write: if request.auth != null;
    }
    match /appointments/{id} {
      allow create: if true; // Allow guest booking
      allow read, update, delete: if request.auth != null;
    }
    match /push_subscriptions/{id} {
      allow read, write: if false; // Only accessible via server-side Admin SDK
    }

    // Rules for stores and their store-specific subcollections
    match /stores/{storeId} {
      allow read, write, delete: if request.auth != null;

      match /repairs/{id} {
        allow read, write: if request.auth != null;
      }
      match /customers/{id} {
        allow read, write: if request.auth != null;
      }
      match /inventory/{id} {
        allow read, write: if request.auth != null;
      }
      match /insurance/{id} {
        allow read, write: if request.auth != null;
      }
      match /notifications/{id} {
        allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
        allow create: if request.auth != null;
      }
      match /appointments/{id} {
        allow create: if true; // Allow guest booking
        allow read, update, delete: if request.auth != null;
      }
      match /settings/{id} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
